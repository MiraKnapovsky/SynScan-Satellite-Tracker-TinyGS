# Third TinyGS station for InfluxDB/Grafana only.
# This listener never writes the rotator state.json.
# Geo enrichment stays enabled when gateway location and TLE data are available.
# MQTT login is the same as the main rotator station. Only TINYGS_STATION changes.

TINYGS_USER=YOUR_USER_ID
TINYGS_STATION=YOUR_PASSIVE2_STATION
TINYGS_PASS=YOUR_PASSWORD

# InfluxDB v2
INFLUXDB_URL=http://127.0.0.1:8086
INFLUXDB_ORG=your-org
INFLUXDB_BUCKET=tinygs_passive2
INFLUXDB_TOKEN=your-token
INFLUXDB_MEAS_FRAME=tinygs_frame
INFLUXDB_MEAS_STATE=tinygs_state
INFLUXDB_MEAS_META=tinygs_meta
INFLUXDB_TIMEOUT_MS=10000

# Optional: custom CA bundle for MQTT TLS. Leave empty to use system trust store.
# TINYGS_CAFILE=/path/to/ca-bundle.pem

# Keep this empty so passive ingest is not stamped with tracked_norad from the rotator.
TINYGS_TRACKER_STATUS_FILE=
